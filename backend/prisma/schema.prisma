  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  course      LpCourse                          @relation(fields: [courseId], references: [id])
  photos      LpPhysicalVisitPhoto[]
  history     LpPhysicalVisitHistory[]
