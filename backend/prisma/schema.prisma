// ─── Auth / Users ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  emailConfirmed Boolean @default(false) @map("email_confirmed")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastSignInAt DateTime? @map("last_sign_in_at")

  profile                Profile?
  userRoles              UserRole[]
  appPermissions         AppPermission[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]

  @@map("users")
}

model Profile {
  id          String  @id @map("id") // same as User.id
  displayName String? @map("display_name")
  avatarUrl   String? @map("avatar_url")
  phone       String?

  user User @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UserRole {
  userId String  @map("user_id")
  role   AppRole

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_roles")
}

model AppPermission {
  userId        String   @map("user_id")
  permissionKey String   @map("permission_key")
  grantedBy     String?  @map("granted_by")
  grantedAt     DateTime @default(now()) @map("granted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, permissionKey])
  @@map("app_permissions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Email ────────────────────────────────────────────────────────────────────

model EmailSendLog {
  id              String   @id @default(uuid())
  messageId       String?  @map("message_id")
  templateName    String   @map("template_name")
  recipientEmail  String   @map("recipient_email")
  status          String   // pending | sent | failed | suppressed
  errorMessage    String?  @map("error_message")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([templateName, status, createdAt])
  @@index([recipientEmail])
  @@map("email_send_log")
}

model EmailUnsubscribeToken {
  id        String    @id @default(uuid())
  email     String    @unique
  token     String    @unique
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("email_unsubscribe_tokens")
}

model SuppressedEmail {
  id          String   @id @default(uuid())
  email       String   @unique
  reason      String?
  suppressedAt DateTime @default(now()) @map("suppressed_at")

  @@map("suppressed_emails")
}

model EmailQueue {
  id          String   @id @default(uuid())
  messageId   String   @unique @map("message_id")
  payload     Json
  status      String   @default("pending") // pending | processing | sent | failed | dead
  attempts    Int      @default(0)
  lastAttemptAt DateTime? @map("last_attempt_at")
  processAfter DateTime  @default(now()) @map("process_after")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([status, processAfter])
  @@map("email_queue")
}

// ─── Learning Platform — Programs, Courses, Modules ──────────────────────────

model LpProgram {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  summary     String?
  coverUrl    String?  @map("cover_url")
  published   Boolean  @default(false)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  courses LpCourse[]

  @@map("lp_programs")
}

model LpCourse {
  id                    String   @id @default(uuid())
  programId             String   @map("program_id")
  slug                  String   @unique
  title                 String
  summary               String?
  durationLabel         String?  @map("duration_label")
  coverUrl              String?  @map("cover_url")
  passPct               Int      @default(70) @map("pass_pct")
  maxAttempts           Int?     @map("max_attempts")
  day5GateDays          Int      @default(0) @map("day5_gate_days")
  requiresProductUpload Boolean  @default(false) @map("requires_product_upload")
  requiresInspection    Boolean  @default(false) @map("requires_inspection")
  issuesCertificate     Boolean  @default(false) @map("issues_certificate")
  maxCuisines           Int?     @map("max_cuisines")
  published             Boolean  @default(false)
  sortOrder             Int      @default(0) @map("sort_order")
  productBrief          Json     @default("{}") @map("product_brief")
  inspectionRubric      Json     @default("{}") @map("inspection_rubric")
  certificateTemplate   Json     @default("{}") @map("certificate_template")
  certificateTemplates  Json     @default("[]") @map("certificate_templates")
  welcomeLetter         Json     @default("{}") @map("welcome_letter")
  supportedLanguages    String[] @default(["en"]) @map("supported_languages")
  journeySteps          String[] @default([]) @map("journey_steps")
  sectionOrder          String[] @default([]) @map("section_order")
  resourceCategories    String[] @default([]) @map("resource_categories")
  videoCategories       String[] @default([]) @map("video_categories")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  program            LpProgram           @relation(fields: [programId], references: [id])
  modules            LpModule[]
  days               LpCourseDay[]
  enrolments         LpEnrolment[]
  partnerInvites     LpPartnerInvite[]
  certificates       LpCertificate[]
  partnerCertificates LpPartnerCertificate[]
  productSubmissions LpProductSubmission[]
  partnerEvents      LpPartnerEvent[]
  cuisines           LpCuisine[]
  recipes            LpRecipe[]
  sampleImageGuide   LpSampleImageGuide?
  physicalVisits     LpPhysicalVisit[]
  inspectionSlots    LpInspectionSlot[]
  partnerResources   SftPartnerResource[]
  videos             SftVideo[]

  @@map("lp_courses")
}

model LpCourseDay {
  id               String   @id @default(uuid())
  courseId         String   @map("course_id")
  dayNo            Int      @map("day_no")
  title            String
  summary          String?
  unlockAfterDays  Int      @default(0) @map("unlock_after_days")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  course  LpCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  modules LpModule[]

  @@unique([courseId, dayNo])
  @@map("lp_course_days")
}

model LpModule {
  id                 String       @id @default(uuid())
  courseId           String       @map("course_id")
  sortOrder          Int          @default(0) @map("sort_order")
  type               LpModuleType
  title              String
  summary            String?
  estMinutes         Int?         @map("est_minutes")
  deckId             String?      @map("deck_id")
  videoUrl           String?      @map("video_url")
  readingMd          String?      @map("reading_md")
  filePath           String?      @map("file_path")
  published          Boolean      @default(false)
  slideOverrides     Json         @default("{}") @map("slide_overrides")
  voice              String?
  language           String       @default("en")
  speed              Float        @default(1.0)
  autoplayAdvance    Boolean      @default(true) @map("autoplay_advance")
  defaultSlideSeconds Int         @default(5) @map("default_slide_seconds")
  quizEnabled        Boolean      @default(false) @map("quiz_enabled")
  quizPassPct        Int          @default(70) @map("quiz_pass_pct")
  quizQuestions      Json         @default("[]") @map("quiz_questions")
  dayId              String?      @map("day_id")
  quizPlacement      String       @default("topic") @map("quiz_placement")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  course       LpCourse          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  day          LpCourseDay?      @relation(fields: [dayId], references: [id], onDelete: SetNull)
  deck         SftDeckSetup?     @relation(fields: [deckId], references: [id], onDelete: SetNull)
  progress     LpModuleProgress[]
  quizAttempts LpModuleQuizAttempt[]
  quizzes      LpQuiz[]
  notes        LpModuleNote[]

  @@map("lp_modules")
}

model LpEnrolment {
  id         String             @id @default(uuid())
  userId     String             @map("user_id")
  courseId   String             @map("course_id")
  status     LpEnrolmentStatus  @default(active)
  enrolledAt DateTime           @default(now()) @map("enrolled_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  course LpCourse @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("lp_enrolments")
}

model LpModuleProgress {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  moduleId    String    @map("module_id")
  completedAt DateTime? @map("completed_at")
  progressPct Int       @default(0) @map("progress_pct")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  module LpModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("lp_module_progress")
}

model LpModuleQuizAttempt {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  moduleId    String   @map("module_id")
  attemptNo   Int      @map("attempt_no")
  placement   String   @default("topic")
  questionIds String[] @map("question_ids")
  answers     Json
  scorePct    Float    @map("score_pct")
  passed      Boolean
  createdAt   DateTime @default(now()) @map("created_at")

  module LpModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([userId, moduleId])
  @@map("lp_module_quiz_attempts")
}

model LpModuleNote {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  moduleId  String   @map("module_id")
  body      String   @default("")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module LpModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("lp_module_notes")
}

model LpNotification {
  id          String    @id @default(uuid())
  partnerId   String    @map("partner_id")
  moduleName  String    @map("module_name")
  message     String
  referenceId String?   @map("reference_id")
  status      String    @default("unread")
  createdAt   DateTime  @default(now()) @map("created_at")
  readAt      DateTime? @map("read_at")

  @@index([partnerId, status])
  @@index([partnerId, moduleName])
  @@map("lp_notifications")
}

// ─── SFT Deck Setup ───────────────────────────────────────────────────────────

model SftDeckSetup {
  id              String   @id @default(uuid())
  name            String
  filePath        String   @map("file_path")
  pdfPath         String?  @map("pdf_path")
  voice           String   @default("alloy")
  speed           Float    @default(1.0)
  autoplayAdvance Boolean  @default(true) @map("autoplay_advance")
  active          Boolean  @default(false)
  uploadedBy      String?  @map("uploaded_by")
  uploadedAt      DateTime @default(now()) @map("uploaded_at")

  modules LpModule[]

  @@map("sft_deck_setup")
}

// ─── Partner Invites & Events ─────────────────────────────────────────────────

model LpPartnerInvite {
  id              String    @id @default(uuid())
  courseId        String    @map("course_id")
  recipientName   String    @map("recipient_name")
  recipientEmail  String    @map("recipient_email")
  kitchenLocation String?   @map("kitchen_location")
  message         String?
  token           String    @default(uuid())
  status          String    @default("sent")
  invitedBy       String?   @map("invited_by")
  userId          String?   @map("user_id")
  sentAt          DateTime  @default(now()) @map("sent_at")
  openedAt        DateTime? @map("opened_at")
  acceptedAt      DateTime? @map("accepted_at")
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  course  LpCourse       @relation(fields: [courseId], references: [id])
  tasks   SftPartnerTask[]
  events  LpPartnerEvent[]

  @@index([courseId])
  @@index([userId])
  @@map("lp_partner_invites")
}

model LpPartnerEvent {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  inviteId  String?  @map("invite_id")
  userId    String?  @map("user_id")
  eventType String   @map("event_type")
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  course LpCourse         @relation(fields: [courseId], references: [id])
  invite LpPartnerInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@map("lp_partner_events")
}

// ─── Product Submissions ──────────────────────────────────────────────────────

model LpProductSubmission {
  id          String             @id @default(uuid())
  userId      String             @map("user_id")
  courseId    String             @map("course_id")
  files       Json               @default("[]")
  notes       String?
  status      LpSubmissionStatus @default(pending)
  feedback    String?
  reviewerId  String?            @map("reviewer_id")
  reviewedAt  DateTime?          @map("reviewed_at")
  submittedAt DateTime           @default(now()) @map("submitted_at")

  course LpCourse @relation(fields: [courseId], references: [id])

  @@index([userId, courseId])
  @@map("lp_product_submissions")
}

// ─── Certificates ─────────────────────────────────────────────────────────────

model LpCertificate {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  code      String   @unique
  issuedAt  DateTime @default(now()) @map("issued_at")
  filePath  String?  @map("file_path")
  revokedAt DateTime? @map("revoked_at")

  course LpCourse @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@index([userId])
  @@map("lp_certificates")
}

// One row per (partner, course, additional-certificate-template) — lets a
// course define several extra certificates (beyond the single main one
// above) that all get issued to a partner once they complete the course.
model LpPartnerCertificate {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  courseId   String    @map("course_id")
  templateId String    @map("template_id")
  code       String    @unique
  issuedAt   DateTime  @default(now()) @map("issued_at")
  revokedAt  DateTime? @map("revoked_at")

  course LpCourse @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId, templateId])
  @@index([userId])
  @@map("lp_partner_certificates")
}

// ─── Quizzes ──────────────────────────────────────────────────────────────────

model LpQuiz {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  moduleId  String?  @map("module_id")
  title     String
  isFinal   Boolean  @default(false) @map("is_final")
  shuffle   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  module    LpModule?         @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  questions LpQuizQuestion[]

  @@index([courseId, moduleId])
  @@map("lp_quizzes")
}

model LpQuestion {
  id          String             @id @default(uuid())
  courseId    String             @map("course_id")
  prompt      String
  type        LpQuestionType     @default(single)
  options     Json               @default("[]")
  correct     Json               @default("[]")
  explanation String?
  createdAt   DateTime           @default(now()) @map("created_at")

  quizLinks LpQuizQuestion[]

  @@map("lp_questions")
}

model LpQuizQuestion {
  quizId     String @map("quiz_id")
  questionId String @map("question_id")
  sortOrder  Int    @default(0) @map("sort_order")

  quiz     LpQuiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question LpQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([quizId, questionId])
  @@map("lp_quiz_questions")
}

// ─── Cuisines, Recipes, Assignments ──────────────────────────────────────────

model LpCuisine {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  showCount Int      @default(0) @map("show_count")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  course  LpCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  recipes LpRecipe[]

  @@map("lp_cuisines")
}

model LpRecipe {
  id             String   @id @default(uuid())
  courseId       String   @map("course_id")
  cuisineId      String?  @map("cuisine_id")
  foodName       String   @map("food_name")
  ingredientsMd  String   @default("") @map("ingredients_md")
  prepStepsMd    String?  @map("prep_steps_md")
  cookStepsMd    String?  @map("cook_steps_md")
  imagePath      String?  @map("image_path")
  active         Boolean  @default(true)
  sortOrder      Int      @default(0) @map("sort_order")
  status         String   @default("active")
  createdBy      String?  @map("created_by")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  course  LpCourse    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  cuisine LpCuisine?  @relation(fields: [cuisineId], references: [id], onDelete: SetNull)

  @@map("lp_recipes")
}

model LpSampleImageGuide {
  courseId        String   @id @map("course_id")
  sampleImagePath String?  @map("sample_image_path")
  guidelinesMd    String   @default("") @map("guidelines_md")
  updatedAt       DateTime @updatedAt @map("updated_at")

  course LpCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("lp_sample_image_guide")
}

model LpProductAssignment {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  cuisineId String   @map("cuisine_id")
  recipeId  String   @map("recipe_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, courseId])
  @@map("lp_product_assignments")
}

model LpRecipeAssignment {
  partnerUserId  String   @map("partner_user_id")
  courseId       String   @map("course_id")
  recipeId       String   @map("recipe_id")
  assignedBy     String?  @map("assigned_by")
  assignedMethod String   @default("manual") @map("assigned_method")
  assignedAt     DateTime @default(now()) @map("assigned_at")

  @@id([partnerUserId, courseId])
  @@map("lp_recipe_assignments")
}

// ─── Physical Visits ──────────────────────────────────────────────────────────

model LpPhysicalVisit {
  id                  String          @id @default(uuid())
  userId              String          @map("user_id")
  courseId            String          @map("course_id")
  recipeId            String?         @map("recipe_id")
  productIds          Json            @default("[]") @map("product_ids")
  submissionId        String?         @map("submission_id")
  attemptNo           Int             @default(1) @map("attempt_no")
  partnerLocation     String?         @map("partner_location")
  partnerState        String?         @map("partner_state")
  partnerCountry      String?         @map("partner_country")
  partnerPhone        String?         @map("partner_phone")
  partnerAddress      String?         @map("partner_address")
  cuisineId           String?         @map("cuisine_id")
  visitorName         String?         @map("visitor_name")
  visitorEmail        String?         @map("visitor_email")
  visitorPhone        String?         @map("visitor_phone")
  visitorLocation     String?         @map("visitor_location")
  visitDate           String?         @map("visit_date")
  visitTime           String?         @map("visit_time")
  remarks             String?
