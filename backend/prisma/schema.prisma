  description        String?
  preparationNotes   String?        @map("preparation_notes")
  storageNotes       String?        @map("storage_notes")
  shelfLifeDays      Int?           @map("shelf_life_days")
  shelfLifeCondition String?        @map("shelf_life_condition")
  defaultBatchSize   Float?         @map("default_batch_size")
  defaultYieldQty    Float?         @map("default_yield_qty")
  defaultYieldUnitId String?        @map("default_yield_unit_id")
