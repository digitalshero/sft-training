// =============================================================
// Shero Training Centre — Prisma Schema
// Mirrors the full Supabase PostgreSQL database schema.
// Target: PostgreSQL (local dev) → AWS RDS PostgreSQL (prod)
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

