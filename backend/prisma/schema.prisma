model LpPhysicalVisitHistory {
  id           String    @id @default(uuid())
  visitId      String    @map("visit_id")
  attemptNo    Int       @map("attempt_no")
  visitorName     String?   @map("visitor_name")
  visitorEmail    String?   @map("visitor_email")
  visitorPhone    String?   @map("visitor_phone")
  visitorLocation String?   @map("visitor_location")
  visitDate       String?   @map("visit_date")
  visitTime       String?   @map("visit_time")
  decision        String?
  comments        String?
  photos          Json      @default("[]")
  assignedProducts Json     @default("[]") @map("assigned_products")
  productInspections Json   @default("[]") @map("product_inspections")
  totalProducts    Int?      @map("total_products")
  acceptedProducts Int?      @map("accepted_products")
  rejectedProducts Int?      @map("rejected_products")
  inspectionPercentage Float? @map("inspection_percentage")
  submittedAt     DateTime? @map("submitted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  visit LpPhysicalVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("lp_physical_visit_history")
}

model LpPhysicalVisitToken {
