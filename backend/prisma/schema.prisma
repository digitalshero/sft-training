  @@map("fc_preps")
}

model FcProduct {
  id             String         @id @default(uuid())
  name           String
  code           String         @unique
  brandId        String         @map("brand_id")
  categoryId     String         @map("category_id")
  description    String?
  menuDescription String?       @map("menu_description")
  menuPosition   Int            @default(0) @map("menu_position")
  imageUrl       String?        @map("image_url")
  spiceLevel     Int            @default(0) @map("spice_level")
