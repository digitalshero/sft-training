// ─── Partner onboarding: external payment → admin verification → OTP login ────
// Payment records are written by an external payment integration (handled
// separately) or inserted directly for now — this module only displays and
// manages them once they exist.

model PartnerPayment {
  id                 String   @id @default(uuid())
  externalPartnerId  String?  @map("external_partner_id")
  partnerName        String   @map("partner_name")
  partnerEmail       String   @map("partner_email")
  paymentId          String   @unique @map("payment_id")
  amount             Float
  paymentStatus      String   @default("unpaid") @map("payment_status") // paid | unpaid
  approvalStatus     String   @default("pending") @map("approval_status") // pending | accepted | rejected
  inviteStatus       String   @default("pending") @map("invite_status") // pending | sent
  createdAt          DateTime @default(now()) @map("created_at")

  invite PartnerInvite?

  @@index([partnerEmail])
  @@map("partner_payments")
}

model PartnerInvite {
  id               String   @id @default(uuid())
  partnerPaymentId String   @unique @map("partner_payment_id")
  partnerEmail     String   @map("partner_email")
  inviteToken      String   @unique @map("invite_token")
  inviteLink       String?  @map("invite_link")
  inviteStatus     String   @default("pending") @map("invite_status") // pending | sent
  createdAt        DateTime @default(now()) @map("created_at")

  payment PartnerPayment @relation(fields: [partnerPaymentId], references: [id], onDelete: Cascade)

  @@index([partnerEmail])
  @@map("partner_invites")
}

model PartnerOtp {
  id             String   @id @default(uuid())
  partnerEmail   String   @map("partner_email")
  otpCode        String   @map("otp_code")
  expiresAt      DateTime @map("expires_at")
  verifiedStatus Boolean  @default(false) @map("verified_status")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([partnerEmail])
  @@map("partner_otp")
}
