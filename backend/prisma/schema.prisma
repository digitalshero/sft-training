  activeIn           Boolean        @default(true) @map("active_in")
  activeUs           Boolean        @default(true) @map("active_us")
  manuallyUsed       Boolean        @default(false) @map("manually_used")
  status             FcStatus       @default(active)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

