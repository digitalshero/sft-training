  ptrMultiplierInr    Float    @default(1) @map("ptr_multiplier_inr")
  ptrMultiplierUsd    Float    @default(1) @map("ptr_multiplier_usd")
  ptrFlatInr          Float    @default(0) @map("ptr_flat_inr")
  ptrFlatUsd          Float    @default(0) @map("ptr_flat_usd")
